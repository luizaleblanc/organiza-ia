generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  password  String
  name      String
  createdAt DateTime @default(now())
}

model Invoice {
  id          Int      @id @default(autoincrement())
  description String
  value       Float
  dueDate     DateTime
  createdAt   DateTime @default(now())
}